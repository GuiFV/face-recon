# Copy this file to .env and fill in the blanks. Project settings use the FACE_RECON_ prefix.
# The Roboflow credentials use the plain names ROBOFLOW_API_KEY and ROBOFLOW_WORKSPACE (with no
# prefix), because the bundled inference server reads ROBOFLOW_API_KEY too, so a single value
# covers both the decision service and the inference server.

# --- Roboflow self-hosted inference server (person detection + pose) ---
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
# Inside docker-compose, the server is reachable by its service name. You can set a host:port
# here instead when the inference server runs somewhere else.
FACE_RECON_INFERENCE_SERVER_URL=http://inference-server:9001
FACE_RECON_POSE_MODEL_ID=yolov8n-pose-640
# Pose source: "roboflow" (the inference server above, metered) or "local" (ultralytics
# yolov8-pose on this host, no Roboflow credits). Same COCO keypoints either way.
FACE_RECON_POSE_PROVIDER=roboflow
FACE_RECON_LOCAL_POSE_MODEL_PATH=models/yolov8n-pose.pt
# Run the pose model only while motion is asserted via POST /signal (or while it is actively
# evaluating), instead of on every frame. Set this to true when an integration has its own
# cheap motion signal (a PIR, for example) and drives /signal, so the pose model runs only on a
# real event rather than continuously.
FACE_RECON_POSE_REQUIRES_SIGNAL=false

# --- Camera stream: set to your camera's MJPEG/RTSP URL ---
FACE_RECON_STREAM_URL=http://camera-host:8081

# --- Identity (ArcFace via insightface) ---
# reference set built by enrolment/enrol.py; mounted at runtime, never committed
FACE_RECON_REFERENCE_PATH=enrolment/reference/known.npz
FACE_RECON_FACE_MATCH_THRESHOLD=0.42
FACE_RECON_FACE_MATCH_TOP_K=5
# On-screen label for a recognised face in the debug view (put your own name here if you like)
FACE_RECON_MATCH_LABEL=known

# --- Geometry gate (must pass before identity is checked) ---
FACE_RECON_KEYPOINT_MIN_CONFIDENCE=0.3
FACE_RECON_HEAD_SHOULDER_RATIO_MIN=0.25
FACE_RECON_HEAD_SHOULDER_RATIO_MAX=0.75
FACE_RECON_FACE_BODY_SCALE_MIN=0.15
FACE_RECON_FACE_BODY_SCALE_MAX=0.80
FACE_RECON_K_CONSECUTIVE=5

# --- Control inputs ---
# How long an external motion signal (POST /signal), such as a PIR pulse, keeps motion "hot",
# in seconds.
FACE_RECON_EXTERNAL_PIR_TTL_SECONDS=5.0

# --- Outbound webhooks (comma-separated): the box POSTs each event here ---
FACE_RECON_WEBHOOK_URLS=

# --- Live CV runtime (the GPU host; off by default so the app/tests stand up bare) ---
FACE_RECON_LIVE_ENABLED=false
FACE_RECON_FACE_USE_GPU=true
FACE_RECON_FACE_LANDMARKER_MODEL_PATH=models/face_landmarker.task

# --- Advanced (optional; sane defaults live in the code) ---
# State machine timing (seconds): FACE_RECON_IDLE_QUIET_SECONDS,
#   FACE_RECON_ARMING_COUNTDOWN_SECONDS, FACE_RECON_EVAL_WINDOW_SECONDS,
#   FACE_RECON_CHALLENGE_WINDOW_SECONDS, FACE_RECON_CHALLENGE_RETRIES,
#   FACE_RECON_ALARM_GRACE_SECONDS
# Liveness: FACE_RECON_ENABLED_CHALLENGES=smile,blink,turn_left,turn_right ; and the thresholds
#   FACE_RECON_SMILE_NEUTRAL_BELOW / _SMILE_ABOVE / _BLINK_OPEN_ABOVE /
#   _BLINK_CLOSED_BELOW / _TURN_CENTRE_BAND / _TURN_THRESHOLD

# --- Service ---
FACE_RECON_LOG_LEVEL=INFO
FACE_RECON_METRICS_ENABLED=true
