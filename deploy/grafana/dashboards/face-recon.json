{
  "title": "face-recon",
  "uid": "face-recon",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Processed FPS",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "face_recon_fps", "legendFormat": "fps" }]
    },
    {
      "type": "timeseries",
      "title": "Pipeline latency (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(face_recon_pipeline_latency_seconds_bucket[1m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(face_recon_pipeline_latency_seconds_bucket[1m]))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "histogram",
      "title": "Match confidence distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(face_recon_match_confidence_bucket[5m])", "legendFormat": "{{le}}" }]
    },
    {
      "type": "histogram",
      "title": "Liveness head motion distribution",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "rate(face_recon_liveness_head_motion_bucket[5m])", "legendFormat": "{{le}}" }]
    },
    {
      "type": "timeseries",
      "title": "Spoof flags by check",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [{ "expr": "rate(face_recon_spoof_flags_total[5m])", "legendFormat": "{{check}}" }]
    },
    {
      "type": "stat",
      "title": "Greetings vs strangers (total)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "face_recon_greetings_total", "legendFormat": "greetings" },
        { "expr": "face_recon_strangers_total", "legendFormat": "strangers" }
      ]
    }
  ]
}
